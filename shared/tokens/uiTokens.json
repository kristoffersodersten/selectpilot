{
  "schema_version": "mue-ui-tokens.v1",
  "layout": {
    "base_grid": 8,
    "sub_grid": 4,
    "max_visible_panels": 3,
    "max_visible_states": 5,
    "breakpoint_single_column": 1080,
    "column_widths": {
      "left": 320,
      "center_min": 360,
      "right": 320
    },
    "panel_gap": 16,
    "panel_padding": 16,
    "panel_radius": 16
  },
  "motion": {
    "duration_ms": {
      "quick": 120,
      "standard": 160,
      "emphasis": 240
    },
    "easing": {
      "standard": "ease",
      "decelerate": "cubic-bezier(0.22, 1, 0.36, 1)"
    },
    "reduce_motion_supported": true
  },
  "color": {
    "surface": {
      "primary": "#ffffff",
      "secondary": "#f8f8f9",
      "overlay": "rgba(15, 23, 42, 0.62)"
    },
    "text": {
      "primary": "#111827",
      "secondary": "#6b7280",
      "inverse": "#f8fafc"
    },
    "semantic": {
      "success": "#0f766e",
      "error": "#ef4444",
      "warning": "#f59e0b"
    }
  },
  "hard_rule": "if_feature_fails_any_required_fat_dimension_it_must_not_enter_runtime_ui",
  "required_fat_dimensions": [
    "layout_contract",
    "topology_contract",
    "token_contract"
  ]
}
