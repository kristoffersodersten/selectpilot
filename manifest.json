{
  "manifest_version": 3,
  "name": "SelectPilot",
  "description": "Privacy-first local browser copilot for selected text, powered by Ollama",
  "version": "1.0.0",
  "minimum_chrome_version": "127",
  "icons": {
    "128": "assets/icon128.png",
    "256": "assets/icon256.png",
    "512": "assets/icon512.png"
  },
  "permissions": ["activeTab", "storage", "scripting", "tabs", "sidePanel"],
  "host_permissions": ["http://chromeai.local/*"],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Open SelectPilot"
  },
  "side_panel": {
    "default_path": "panel/panel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/icon128.png", "assets/icon256.png", "assets/icon512.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
